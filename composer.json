{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "repositories": [
        {
            "type": "composer",
            "url": "https://repo.backpackforlaravel.com/"
        },
        {
            "type": "composer",
            "url": "https://composer.fluxui.dev"
        }
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "algolia/algoliasearch-client-php": "^3.2",
        "anhskohbo/no-captcha": "^3.6",
        "backpack/crud": "^7.0",
        "backpack/permissionmanager": "^7.0",
        "backpack/pro": "^3.0",
        "backpack/theme-tabler": "^2.0",
        "barryvdh/laravel-dompdf": "^3.0",
        "bugsnag/bugsnag-laravel": "^2.29",
        "consoletvs/charts": "6.*",
        "creagia/laravel-sign-pad": "^2.1",
        "cviebrock/eloquent-sluggable": "^12.0",
        "guzzlehttp/guzzle": "^7.9",
        "inertiajs/inertia-laravel": "^2.0",
        "intervention/image": "^3.11",
        "intervention/image-laravel": "^1.5",
        "laravel-toolkit/laravel-db-seeder-export": "^1.0",
        "laravel/cashier": "^15.0",
        "laravel/fortify": "^1.34",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.3",
        "laravel/scout": "^10.2",
        "laravel/tinker": "^2.10",
        "league/commonmark": "^2.7",
        "league/flysystem": "^3.29",
        "league/flysystem-aws-s3-v3": "^3.0",
        "league/flysystem-ftp": "^3.29",
        "league/flysystem-sftp-v3": "^3.28",
        "league/oauth2-client": "^2.7",
        "livewire/flux": "^2.12",
        "livewire/flux-pro": "^2.12",
        "livewire/livewire": "^4.1",
        "lloadout/microsoftgraph": "^1.15",
        "maatwebsite/excel": "^3.1",
        "mews/purifier": "^3.4",
        "microsoft/microsoft-graph": "^1.110",
        "paypal/paypal-checkout-sdk": "^1.0",
        "predis/predis": "^2.3",
        "pusher/pusher-php-server": "^7.2",
        "reliese/laravel": "^1.2",
        "spatie/browsershot": "^5.0",
        "spatie/laravel-activitylog": "^4.9",
        "spatie/laravel-image-optimizer": "^1.8",
        "spatie/laravel-medialibrary": "^11.19",
        "spatie/laravel-permission": "^6.7",
        "spatie/laravel-sitemap": "^7.3",
        "spatie/laravel-translatable": "^6.9",
        "srmklive/paypal": "~3.0",
        "twilio/sdk": "^8.3"
    },
    "require-dev": {
        "backpack/generators": "^4.0",
        "fakerphp/faker": "^1.9.1",
        "laravel/breeze": "^2.0",
        "laravel/dusk": "^8.3",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0",
        "spatie/laravel-ignition": "^2.0",
        "spatie/laravel-ray": "^1.40"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "post-install-cmd": [
            "@php artisan storage:link --quiet",
            "@php artisan basset:cache 2>/dev/null || true"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
